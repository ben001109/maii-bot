generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id          String      @id @default(uuid())
  discordId   String      @unique
  money       Int         @default(0)
  enterprises Enterprise[]
}

model Enterprise {
  id          String   @id @default(uuid())
  name        String
  type        String
  level       Int
  income      Int
  createdAt   DateTime @default(now())
  playerId    String
  player      Player   @relation(fields: [playerId], references: [id])
}
