# 基本設定
NODE_ENV=development  # development, production

# Discord 設定
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_bot_client_id
DISCORD_GUILD_ID=your_guild_id
OWNER_ID=your_discord_id

# 資料庫設定
DATABASE_URL=postgresql://bot:dbpassword@postgres:5432/maii

# Redis 設定
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# 日誌設定
LOG_LEVEL=info  # debug, info, warn, error

# 應用設定
COMMAND_PREFIX=!
COMMAND_COOLDOWN=3
TIMEZONE=Asia/Taipei

# 經濟系統設定
DAILY_AMOUNT=100
WORK_MIN_AMOUNT=10
WORK_MAX_AMOUNT=50
START_BALANCE=500
